.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f9fafb;
  padding-bottom: 30rpx;
}

/* 图片区域 */
.image-section {
  width: 100%;
  height: 400rpx;
  background-color: #e2e8f0;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
}

.question-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* 内容区域 */
.content-section {
  flex: 1;
  padding: 0 30rpx;
}

.info-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  height: 80rpx;
  box-sizing: border-box;
}

.picker-value {
  font-size: 30rpx;
  color: #1f2937;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  color: #9ca3af;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 难度选择器 */
.difficulty-selector {
  display: flex;
  justify-content: space-between;
}

.difficulty-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 20rpx 0;
  background-color: #f9fafb;
  border-radius: 12rpx;
  margin: 0 10rpx;
}

.difficulty-item:first-child {
  margin-left: 0;
}

.difficulty-item:last-child {
  margin-right: 0;
}

.difficulty-item.active {
  background-color: rgba(34, 197, 94, 0.1);
  border: 2rpx solid #22c55e;
}

.star-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 8rpx;
  color: #9ca3af;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.difficulty-item.active .star-icon {
  color: #22c55e;
}

.difficulty-item text {
  font-size: 26rpx;
  color: #4b5563;
}

.difficulty-item.active text {
  color: #22c55e;
}

/* 输入框 */
.form-input {
  display: flex;
  align-items: center;
  background-color: #f9fafb;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 80rpx;
}

.form-input input {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
}

.add-tag {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: #22c55e;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  font-weight: bold;
}

/* 标签容器 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
  margin-top: -10rpx;
}

.tag {
  background-color: rgba(34, 197, 94, 0.1);
  color: #22c55e;
  border-radius: 30rpx;
  padding: 8rpx 20rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}

.tag-close {
  margin-left: 8rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 文本域 */
.form-textarea {
  background-color: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  min-height: 120rpx;
}

.form-textarea textarea {
  width: 100%;
  min-height: 80rpx;
  font-size: 30rpx;
  line-height: 1.5;
}

/* AI识别结果 */
.recognition-content {
  background-color: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  min-height: 120rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: #4b5563;
}

/* 按钮区域 */
.buttons-container {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}

.primary-button, .secondary-button {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: 500;
}

.primary-button {
  background-color: #22c55e;
  color: white;
  margin-left: 20rpx;
}

.secondary-button {
  background-color: #f3f4f6;
  color: #4b5563;
} 